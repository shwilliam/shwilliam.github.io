---
priority: 1.0
changefreq: 'monthly'
---

<h2>Work</h2>

<ul>
  {% assign sortedPosts = collections.projects | reverse %}
  {% for post in sortedPosts %}
    <li>
      <h3>
        {{post.data.title}}
      </h3>
      <p>
        {{post.data.description}}
      </p>
      <a href="{{post.data.source}}">
        source
      </a>
      {% if post.data.link %}
        <a href="{{post.data.link}}">
          demo
        </a>
      {% endif %}
    </li>
  {% endfor %}
</ul>
