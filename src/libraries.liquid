---
layout: templates/base.liquid
title: Components & Libraries
priority: 1.0
changefreq: 'monthly'
---

{% capture css %}
  {% include css/work.css %}
{% endcapture %}

<style>
  {{ css | cssmin }}
</style>

{% include templates/body-start.liquid %}

<div class='contribution__container'>
  <section class='contribution__profile-overview site-content site-content--l'>
    <div class='contribution__profile'>
      <div class='contribution__profile-header'>
        <div class='contribution__avatar-container'>
          <img src='/images/me.jpg' alt=''>
        </div>

        <div class='contribution__profile-title'>
          <a
            aria-label='GitHub portfolio'
            class='title title--accent title--main'
            href='https://github.com/shwilliam/'
            rel='me'
          >
            @shwilliam
          </a>

          <p class='contribution__status'>
            💫 a11y dreams
          </p>
        </div>

        <ul class='contribution__stats-list'>
          <li class='contribution__stats-item'>
            <a class='contribution__stats-link' href='https://github.com/shwilliam?tab=repositories&type=source' target='_blank' rel='noopener noreferrer'>
              <p class='contribution__stat-title'>
                Repos
              </p>
              <p class='contribution__stat'>
                <span class='contribution__stat-num'>{{github.repos}}</span>
              </p>
            </a>
          </li>

          <li class='contribution__stats-item'>
            <a class='contribution__stats-link' href='https://www.npmjs.com/~shwilliam' target='_blank' rel='noopener noreferrer'>
              <p class='contribution__stat-title'>
                Downloads <span class='contribution__stat-info'>(npm)</span>
              </p>
              <p class='contribution__stat'>
                <span class='contribution__stat-num'>{{npm}}</span> yearly
              </p>
            </a>
          </li>
        </ul>
      </div>

      <div class='contribution__profile-content contribution__profile-content--mobile'>
        <p class='contribution__list-title'>Recent Contributions</p>

        <ul class='contribution__list'>
          {% assign sortedContributions = collections.contributions | reverse %}
          {% for contribution in sortedContributions %}
            <li class='padded--s'>
              <a class='contribution__link' href='{{ contribution.data.url }}' target='_blank' rel='noopener noreferrer'>
                <span class='contribution__info'>
                  {{ contribution.data.owner }}/{{ contribution.data.repo }}
                  (#{{ contribution.data.number }})
                </span><span class='hidden hidden--mobile-s'>:</span>
                <span class='contribution__title'>
                  {{ contribution.data.title }}
                </span>
              </a>
            </li>
          {% endfor %}
        </ul>

        <p class='contribution__list-footer'>
          More on 
          <a href='https://github.com/shwilliam' rel='me'>
            GitHub
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class='site-content site-content--l'>
    <h1 class='title padded hidden hidden--desktop'>Libraries & Components</h1>
    <ul class='work__grid'>
      {% assign sortedPosts = collections.libraries | reverse %}
      {% for post in sortedPosts %}
        <li class='work__grid-item'>
          <div class='work__header'>
            <h2 class='work__title'>
              <a class='work__title-link' href='{{post.data.source}}' target='_blank' rel='noopener noreferrer'>
                <span class='work__title-icon' aria-hidden='true'>
                  {% include icons/repo.svg %}
                </span>
                {% if post.data.brackets %}
                  {{post.data.prefix}} &lt;{{post.data.title}}/&gt;
                {% else %}
                  {{post.data.title}}
                {% endif %}
              </a>
            </h2>
          </div>

          <p class='work__description'>
            {{post.data.description}}
          </p>

          <div class='work__actions'>
            <a class='button work__action' href='{{post.data.source}}' target='_blank' rel='noopener noreferrer'>
              <span aria-hidden='true'>
                {% include icons/github.svg %}
              </span>
              source
            </a>
            {% if post.data.link %}
              <a class='button work__action' href='{{post.data.link}}' target='_blank' rel='noopener noreferrer'>
                <span aria-hidden='true'>
                  {% include icons/compass.svg %}
                </span>
                demo
              </a>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>

    <p class='more'>
      See more on
      <a href='https://github.com/shwilliam' rel='me'>
        GitHub
      </a>
    </p>
  </section>
</div>

<svg id="svgfilters" aria-hidden="true" style="position: absolute; width: 0; height: 0; overflow: hidden;" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
  <defs>
    <filter id="red-sunset" x="-10%" y="-10%" width="120%" height="120%" filterUnits="objectBoundingBox" primitiveUnits="userSpaceOnUse" color-interpolation-filters="sRGB">
      <feColorMatrix type="matrix" values=".33 .33 .33 0 0
        .33 .33 .33 0 0
        .33 .33 .33 0 0
        0 0 0 1 0" in="SourceGraphic" result="colormatrix"/>
      <feComponentTransfer in="colormatrix" result="componentTransfer">
        <feFuncR type="table" tableValues="0.27 0.86 0.97"/>
        <feFuncG type="table" tableValues="0.01 0.08 0.81"/>
        <feFuncB type="table" tableValues="0.02 0.24 0.05"/>
        <feFuncA type="table" tableValues="0 1"/>
      </feComponentTransfer>
      <feBlend mode="normal" in="componentTransfer" in2="SourceGraphic" result="blend"/>
    </filter>
  </defs>
</svg>
